# Application environment: 'local' (uses SSH if enabled) or 'server' (direct connect)
APP_ENV=local

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=deploy_logs

# SSH Tunnel Configuration (Used if APP_ENV=local)
USE_SSH=true
SSH_HOST=your_ssh_ip
SSH_PORT=22
SSH_USER=ubuntu
SSH_KEY_PATH=C:\path\to\your\private_key (NOT the .pub file)
# SSH_PASSWORD=your_ssh_password (if no key)